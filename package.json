{
  "name": "aios",
  "private": true,
  "version": "1.3.3",
  "description": "AI Agent Operating System — The single command center for AI-assisted software creation",
  "main": "dist-electron/main.cjs",
  "bin": {
    "aios": "dist-cli/aios.cjs"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "cli": "node scripts/build-cli.cjs",
    "build:cli": "node scripts/build-cli.cjs",
    "prepare": "node scripts/prepare-cli.cjs || true",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "@xyflow/react": "^12.6.0",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.500.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0",
    "recharts": "^2.15.0",
    "simple-git": "^3.27.0",
    "zustand": "^5.0.5"
  },
  "optionalDependencies": {
    "node-pty": "^1.1.0-beta34"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "jsdom": "^25.0.1",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^2.1.9"
  },
  "build": {
    "appId": "com.aios.app",
    "productName": "AIOS",
    "npmRebuild": false,
    "publish": [
      {
        "provider": "generic",
        "url": "https://aiosapp.vercel.app/downloads"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/node-pty/**/*",
      "dist-electron/pty-worker.cjs",
      "dist/logo.png"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/logo.png"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
